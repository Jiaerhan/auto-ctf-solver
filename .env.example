# Copy this file to .env and fill in your own values
# cp .env.example .env

# Required: Your Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: Model selection
ANTHROPIC_MODEL=claude-sonnet-4-6

# Optional: Docker container for tool execution
CTF_DOCKER_CONTAINER=ctf-tools-agent2
CTF_DOCKER_TIMEOUT=300

# Optional: Working and output directories
CTF_WORK_DIR=./work
CTF_OUTPUT_DIR=./output
CTF_SCREENSHOT_DIR=./screenshots

# Optional: Rate limiting (compliance)
CTF_RATE_LIMIT_DELAY=1.0
CTF_MAX_THREADS=2

# Optional: Writeup output formats (comma-separated: docx,md)
CTF_WRITEUP_FORMATS=docx,md
